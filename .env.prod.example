# ============================================================
# BACKEND — Django
# ============================================================
SECRET_KEY=genera-una-con-openssl-rand-base64-32
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,<tu-ec2-public-ip>,<tu-dominio.cloudfront.net>
CORS_ALLOWED_ORIGINS=https://<tu-dominio.cloudfront.net>

# Database (PostgreSQL dentro del mismo EC2)
POSTGRES_DB=FitnessChat_db
POSTGRES_USER=FitnessChat
POSTGRES_PASSWORD=FitnessChat
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# AI
GROQ_API_KEY=tu-groq-api-key

# USDA (opcional)
USDA_API_KEY=tu-usda-api-key

# ============================================================
# FRONTEND — Vite / React
# ============================================================
VITE_API_BASE_URL=https://<tu-dominio.cloudfront.net>/api
VITE_APP_NAME=FitnessChat
