# ============================================================
# BACKEND — Django
# ============================================================
SECRET_KEY=django-insecure-cambiar-en-produccion-generalo-con-openssl
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
POSTGRES_DB=FitnessChat_db
POSTGRES_USER=FitnessChat
POSTGRES_PASSWORD=FitnessChat
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# AI
GROQ_API_KEY=your-groq-api-key-here

# ============================================================
# FRONTEND — Vite / React
# ============================================================
VITE_API_BASE_URL=http://localhost:8000/api
VITE_APP_NAME=FitnessChat

# ============================================================
# AWS / Deploy (opcional — solo para desplegar en producción)
# ============================================================
# EC2_SSH_KEY_PATH=~/.ssh/fitnesschat-deploy-v2.pem
# EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
# EC2_PUBLIC_IP=xx.xxx.xxx.xxx
